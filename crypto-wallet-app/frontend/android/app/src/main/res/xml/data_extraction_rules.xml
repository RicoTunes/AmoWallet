<?xml version="1.0" encoding="utf-8"?>
<!--
    MILITARY-GRADE DATA EXTRACTION RULES
    Android 12+ backup/transfer prevention
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Disallow all cloud backups for security -->
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <!-- Disallow device-to-device transfer -->
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
