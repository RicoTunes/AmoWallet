<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Development configuration - allow cleartext (HTTP) for testing -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    
    <!-- Development configuration - allow localhost and local network for testing -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">172.20.10.6</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
    
    <!-- Your production domain - HTTPS only with certificate pinning -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.yourdomain.com</domain>
        <domain includeSubdomains="true">staging-api.yourdomain.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <!-- Uncomment and add your certificate pins for production
            <certificates src="@raw/your_certificate" />
            -->
        </trust-anchors>
        <!-- Certificate pinning - uncomment and add your pins for production
        <pin-set expiration="2025-12-31">
            <pin digest="SHA-256">YOUR_CERTIFICATE_PIN_HERE=</pin>
            <pin digest="SHA-256">YOUR_BACKUP_PIN_HERE=</pin>
        </pin-set>
        -->
    </domain-config>
</network-security-config>
