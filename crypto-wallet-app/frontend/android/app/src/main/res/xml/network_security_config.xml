<?xml version="1.0" encoding="utf-8"?>
<!--
    MILITARY-GRADE NETWORK SECURITY CONFIG
    - Blocks all cleartext (HTTP) traffic
    - Only allows HTTPS connections
    - Certificate pinning for production API
-->
<network-security-config>
    <!-- PRODUCTION: Block all cleartext traffic -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Only trust system CAs -->
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
    
    <!-- Production API - Certificate Pinning for Railway -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">amowallet-backend-production.up.railway.app</domain>
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
        <!-- Pin Let's Encrypt Root Certificates (Railway uses Let's Encrypt) -->
        <pin-set expiration="2027-01-01">
            <!-- ISRG Root X1 -->
            <pin digest="SHA-256">C5+lpZ7tcVwmwQIMcRtPbsQtWLABXhQzejna0wHFr8M=</pin>
            <!-- ISRG Root X2 (Backup) -->
            <pin digest="SHA-256">diGVwiVYbubAI3RW4hB9xU8e/CH2GnkuvVFZE8zmgzI=</pin>
        </pin-set>
    </domain-config>
    
    <!-- Trusted third-party APIs - HTTPS only -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.coingecko.com</domain>
        <domain includeSubdomains="true">blockstream.info</domain>
        <domain includeSubdomains="true">mempool.space</domain>
        <domain includeSubdomains="true">api.etherscan.io</domain>
        <domain includeSubdomains="true">api.bscscan.com</domain>
        <domain includeSubdomains="true">api.binance.com</domain>
        <domain includeSubdomains="true">bsc-dataseed.binance.org</domain>
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </domain-config>
</network-security-config>
