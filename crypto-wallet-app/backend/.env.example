# Environment Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/crypto_wallet
REDIS_URL=redis://localhost:6379

# Blockchain API Keys
INFURA_PROJECT_ID=your_infura_project_id_here
INFURA_PROJECT_SECRET=your_infura_project_secret_here
ETHERSCAN_API_KEY=your_etherscan_api_key_here
BSCSCAN_API_KEY=your_bscscan_api_key_here
TRONGRID_API_KEY=your_trongrid_api_key_here
COINGECKO_API_KEY=your_coingecko_api_key_here

# Wallet Security
ENCRYPTION_KEY=your_32_character_encryption_key_here
JWT_SECRET=your_jwt_secret_key_here

# DEX Configuration
UNISWAP_V3_ROUTER=0xE592427A0AEce92De3Edee1F18E0157C05861564
PANCAKESWAP_V3_ROUTER=0x13f4EA83D0bd40E75C8222255bc855a974568Dd4
SUNSWAP_ROUTER=0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d

# Security Settings
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
